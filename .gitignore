###############################################################################
# DentaCare Server - Git Ignore
#
# Backend Stack:
# Node.js + Express
# MongoDB
# JWT Authentication
# Cloudinary
# Email OTP Service
###############################################################################

##############################
# Node dependencies
##############################
node_modules/

##############################
# Logs
##############################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

##############################
# Runtime data
##############################
pids
*.pid
*.seed
*.pid.lock

##############################
# Environment variables
##############################
.env
.env.*
!.env.example

##############################
# Build output
##############################
dist/
build/

##############################
# Coverage / testing
##############################
coverage/
.nyc_output/

##############################
# Temporary files
##############################
tmp/
temp/

##############################
# Uploaded files
##############################
uploads/
storage/

##############################
# Database dumps
##############################
*.sql
*.dump
*.bak
*.db

##############################
# OS generated files
##############################
.DS_Store
Thumbs.db

##############################
# IDE files
##############################
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

##############################
# Package lock backups
##############################
*.tgz
*.zip

##############################
# Optional Docker ignore
##############################
docker-compose.override.yml
